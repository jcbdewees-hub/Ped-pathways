// WALK-THROUGH WIZARD
// ═══════════════════════════════
function Wizard({teaching,weightKg,doses}){
  var s1=useState(null),obvious=s1[0],setObvious=s1[1];
  var s2=useState(null),febrile=s2[0],setFebrile=s2[1];
  var s3=useState(null),jointConcern=s3[0],setJointConcern=s3[1];
  var s4=useState(null),kocherRisk=s4[0],setKocherRisk=s4[1];
  var s5=useState(null),ageGroup=s5[0],setAgeGroup=s5[1];
  var s6=useState(null),redFlags=s6[0],setRedFlags=s6[1];
  var s7=useState(null),localizable=s7[0],setLocalizable=s7[1];
  var s8=useState(null),hipConcern=s8[0],setHipConcern=s8[1];

  function reset(){setObvious(null);setFebrile(null);setJointConcern(null);setKocherRisk(null);setAgeGroup(null);setRedFlags(null);setLocalizable(null);setHipConcern(null);}

  return(<Pad>
    <Q text="Walk-Through" sub="Systematic evaluation of the limping child"/>
    <TeachBox id="overview" teaching={teaching}/>

    {/* STEP 1: Obvious cause */}
    <Card title="Step 1 — Obvious Cause?" color={C.primary}>
      <div style={{fontSize:13,lineHeight:1.6,marginTop:8,marginBottom:10}}>
        <strong>Is there an obvious benign cause for the limp?</strong><br/>
        <span style={{fontSize:12,color:C.muted}}>Superficial soft tissue injury · Insect bite/sting · Plantar wart · HFMD vesicles · Friction blister · Poorly fitting shoes · Recent IM vaccination</span>
      </div>
      <WizBtn label="Yes — Obvious Benign Cause" sub="Treat the specific cause; no further workup needed" color={C.greenMid} bg={C.greenBg} border={C.greenBorder} selected={obvious==="yes"} onClick={function(){setObvious("yes")}}/>
      <WizBtn label="No — No Obvious Cause" sub="Proceed with systematic evaluation" color={C.primary} bg={C.pLight} border={C.pBorder} selected={obvious==="no"} onClick={function(){setObvious("no")}}/>
      {obvious==="yes"&&<Alert color={C.greenMid} border={C.greenBorder} bg={C.greenBg} icon="✅" title="Treat Specific Cause">Manage the identified condition. No further limp workup needed unless symptoms persist or worsen.</Alert>}
    </Card>

    {/* STEP 2: Febrile / infection signs */}
    {obvious==="no"&&(<Card title="Step 2 — Fever or Signs of Infection?" color={C.red}>
      <div style={{fontSize:13,marginBottom:10}}><strong>Does the child have fever or localized signs of infection?</strong><br/><span style={{fontSize:12,color:C.muted}}>Fever · Exquisite joint tenderness with marked ROM limitation · Focal redness/warmth/swelling · Ill appearance</span></div>
      <WizBtn label="Yes — Febrile or Signs of Infection" sub="Evaluate for septic arthritis, osteomyelitis" color={C.red} bg={C.redBg} border={C.redBorder} selected={febrile==="yes"} onClick={function(){setFebrile("yes")}}/>
      <WizBtn label="No — Afebrile, No Infection Signs" color={C.greenMid} bg={C.greenBg} border={C.greenBorder} selected={febrile==="no"} onClick={function(){setFebrile("no")}}/>
    </Card>)}

    {/* STEP 3a: Febrile — Joint concern */}
    {obvious==="no"&&febrile==="yes"&&(<Card title="Step 3 — Septic Joint Evaluation" color={C.red}>
      <div style={{fontSize:13,marginBottom:10}}><strong>Is there concern for septic arthritis (especially hip)?</strong><br/><span style={{fontSize:12,color:C.muted}}>Exquisitely painful joint · Refusal to bear weight · Hip held in flexion/abduction/ER · Pain with any ROM attempt</span></div>
      <div style={{background:C.amberBg,border:"1.5px solid "+C.amberBorder,borderRadius:8,padding:"10px 12px",marginBottom:10}}>
        <div style={{fontSize:12,fontWeight:700,color:C.amberMid,marginBottom:4}}>Kocher Criteria for Septic Hip</div>
        <div style={{fontSize:11,lineHeight:1.6}}>1. Fever &gt;38.5°C<br/>2. Non-weight-bearing<br/>3. ESR &gt;40 mm/hr<br/>4. WBC &gt;12,000/µL<br/>(+5th: CRP &gt;2 mg/dL)<br/><strong>0 = &lt;0.2% · 1 = 3% · 2 = 40% · 3 = 93% · 4 = 99%</strong></div>
      </div>
      <WizBtn label="High Suspicion — Likely Septic Joint" sub="≥2 Kocher criteria OR clinical gestalt" color={C.red} bg={C.redBg} border={C.redBorder} selected={jointConcern==="septic"} onClick={function(){setJointConcern("septic")}}/>
      <WizBtn label="Moderate Suspicion — Possible Septic vs Transient Synovitis" sub="0–1 Kocher criteria, some ROM tolerated, child not toxic" color={C.amberMid} bg={C.amberBg} border={C.amberBorder} selected={jointConcern==="moderate"} onClick={function(){setJointConcern("moderate")}}/>
      <WizBtn label="Low Suspicion — Likely Not Septic Joint" sub="Localized to bone/soft tissue, not joint; or cellulitis/abscess" color={C.blue} bg={C.blueBg} border={C.blueBorder} selected={jointConcern==="low"} onClick={function(){setJointConcern("low")}}/>

      {jointConcern==="septic"&&(<Alert color={C.red} border={C.redBorder} bg={C.redBg} icon="🚨" title="EMERGENT — Septic Joint">
        <strong>Emergency bedside US</strong> of the hip (or affected joint)<br/>
        <strong>Labs:</strong> CBC, ESR, CRP, blood culture<br/>
        <strong>If effusion present → Aspiration</strong> (WBC count, gram stain, culture)<br/>
        <strong>Orthopedic consult STAT</strong> — surgical drainage if confirmed<br/>
        <strong>IV Antibiotics</strong> after culture obtained:<br/>
        — Cefazolin {doses?doses.cefazolinMax+" mg":"25 mg/kg"} IV (covers MSSA, Kingella)<br/>
        — Add Vancomycin {doses?doses.vanc+" mg":"15 mg/kg"} if MRSA concern<br/>
        <strong>→ Admit</strong>
      </Alert>)}
      {jointConcern==="moderate"&&(<Alert color={C.amberMid} border={C.amberBorder} bg={C.amberBg} icon="🟡" title="Transient Synovitis vs Septic — Evaluate Further">
        <strong>Obtain:</strong> CBC, ESR, CRP, blood culture<br/>
        <strong>US hip</strong> — if effusion present and clinical ambiguity → <strong>aspirate</strong><br/>
        If markers low + child bearing some weight + afebrile/low-grade: likely transient synovitis<br/>
        — Ibuprofen {doses?doses.ibu+" mg":"10 mg/kg"} PO Q6h<br/>
        — Discharge with <strong>mandatory 24–48h follow-up</strong><br/>
        — Return immediately if fever, unable to walk, or worsening pain
      </Alert>)}
      {jointConcern==="low"&&(<Alert color={C.blue} border={C.blueBorder} bg={C.blueBg} icon="ℹ️" title="Evaluate for Osteomyelitis / Soft Tissue Infection">
        <strong>Focal bone tenderness:</strong> XR of affected area + CBC, ESR, CRP, blood culture → osteomyelitis workup<br/>
        <strong>Cellulitis/abscess:</strong> Consider US for abscess/foreign body<br/>
        <strong>Myositis:</strong> If bilateral calf/thigh pain + influenza symptoms → check CK if severe
      </Alert>)}
      <TeachBox id="septicHip" teaching={teaching}/>
      <TeachBox id="transientSynovitis" teaching={teaching}/>
    </Card>)}

    {/* STEP 3b: Afebrile — Age group */}
    {obvious==="no"&&febrile==="no"&&(<Card title="Step 3 — Age Group" color={C.primary}>
      <div style={{fontSize:13,marginBottom:10}}><strong>What is the child's age?</strong><br/><span style={{fontSize:12,color:C.muted}}>Age-specific diagnoses drive the evaluation</span></div>
      <WizBtn label="Toddler / Young Child (1–5 years)" sub="Toddler's fracture · Transient synovitis · DDH · NAT · Discitis · Malignancy" color={C.red} bg={C.redBg} border={C.redBorder} selected={ageGroup==="toddler"} onClick={function(){setAgeGroup("toddler")}}/>
      <WizBtn label="School Age (5–12 years)" sub="Legg-Calvé-Perthes · Transient synovitis · Osteomyelitis · Apophysitis · JIA" color={C.amberMid} bg={C.amberBg} border={C.amberBorder} selected={ageGroup==="school"} onClick={function(){setAgeGroup("school")}}/>
      <WizBtn label="Adolescent (13–19 years)" sub="SCFE · Stress fracture · Ligament injury · Apophysitis · Osgood-Schlatter · OCD" color={C.blue} bg={C.blueBg} border={C.blueBorder} selected={ageGroup==="adolescent"} onClick={function(){setAgeGroup("adolescent")}}/>
    </Card>)}

    {/* STEP 4: Red flags */}
    {obvious==="no"&&febrile==="no"&&ageGroup!==null&&(<Card title="Step 4 — Red Flag Screen" color={C.red}>
      <div style={{fontSize:13,marginBottom:10}}><strong>Are any red flags present?</strong></div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6,marginBottom:12}}>
        {["Night pain / pain at rest","Inability to bear weight","Persistent or worsening limp >2 weeks","Systemic symptoms (pallor, weight loss, bruising)","Suspected NAT (inconsistent mechanism)","Hip pain with decreased internal rotation","Neurologic deficits (weakness, sensory changes)","Back pain with fever or neuro symptoms"].map(function(item){return <div key={item} style={{background:C.redBg,border:"1px solid "+C.redBorder,borderRadius:6,padding:"6px 8px",fontSize:11,fontWeight:500}}>{item}</div>})}
      </div>
      <WizBtn label="Red Flag(s) Present" sub="Warrants urgent workup — labs, imaging, possible consultation" color={C.red} bg={C.redBg} border={C.redBorder} selected={redFlags==="yes"} onClick={function(){setRedFlags("yes")}}/>
      <WizBtn label="No Red Flags" sub="Proceed with age-appropriate evaluation" color={C.greenMid} bg={C.greenBg} border={C.greenBorder} selected={redFlags==="no"} onClick={function(){setRedFlags("no")}}/>

      {redFlags==="yes"&&ageGroup==="adolescent"&&(<Alert color={C.red} border={C.redBorder} bg={C.redBg} icon="🚨" title="Adolescent Red Flags">
        <strong>If hip pain with decreased internal rotation → SCFE until proven otherwise:</strong><br/>
        — <strong>Immediate non-weight-bearing</strong> (crutches or wheelchair)<br/>
        — AP + frog-leg lateral of <strong>BILATERAL pelvis</strong><br/>
        — <strong>Urgent orthopedic consult</strong> for operative fixation<br/><br/>
        <strong>Night pain / rest pain → malignancy screen:</strong> CBC with diff, ESR/CRP, LDH, ALP, uric acid + XR of painful area
      </Alert>)}
      {redFlags==="yes"&&ageGroup==="school"&&(<Alert color={C.red} border={C.redBorder} bg={C.redBg} icon="🚨" title="School-Age Red Flags">
        <strong>Hip pain with Trendelenburg gait → XR bilateral pelvis</strong> (Legg-Calvé-Perthes, early SCFE)<br/>
        <strong>Night pain → malignancy screen:</strong> CBC, ESR/CRP, LDH, ALP + XR<br/>
        <strong>Back pain + fever → consider:</strong> discitis, vertebral osteomyelitis, spinal epidural abscess (MRI if neuro findings)
      </Alert>)}
      {redFlags==="yes"&&ageGroup==="toddler"&&(<Alert color={C.red} border={C.redBorder} bg={C.redBg} icon="🚨" title="Toddler Red Flags">
        <strong>Cannot bear weight → XR tibia/fibula</strong> (toddler's fx). If negative, consider femur, foot XR.<br/>
        <strong>Mechanism inconsistent with developmental stage → NAT:</strong> skeletal survey, social work, CPS<br/>
        <strong>Night pain / systemic symptoms → malignancy screen</strong><br/>
        <strong>Back tenderness → discitis or spinal pathology</strong>
      </Alert>)}
      <TeachBox id="scfe" teaching={teaching}/>
      <TeachBox id="malignancy" teaching={teaching}/>
    </Card>)}

    {/* STEP 5: Localizable? */}
    {obvious==="no"&&febrile==="no"&&ageGroup!==null&&redFlags==="no"&&(<Card title="Step 5 — Can You Localize the Pain?" color={C.blue}>
      <div style={{fontSize:13,marginBottom:10}}><strong>Can you identify a specific site of pain or tenderness on exam?</strong></div>
      <WizBtn label="Yes — Localized" sub="XR AP + lateral of the affected site · Hip pain → bilateral pelvis XR" color={C.blue} bg={C.blueBg} border={C.blueBorder} selected={localizable==="yes"} onClick={function(){setLocalizable("yes")}}/>
      <WizBtn label="No — Non-Localizable" sub="Common in young/nonverbal children" color={C.amberMid} bg={C.amberBg} border={C.amberBorder} selected={localizable==="no"} onClick={function(){setLocalizable("no")}}/>

      {localizable==="yes"&&(<Alert color={C.blue} border={C.blueBorder} bg={C.blueBg} icon="📋" title="Localized — Targeted Imaging">
        <strong>XR AP + lateral of the painful area</strong><br/>
        Knee pain with hip limitation → also get <strong>bilateral pelvis XR</strong> (rule out SCFE, Perthes)<br/>
        Point tenderness at apophysis → may diagnose clinically (Osgood-Schlatter, Sever disease)<br/><br/>
        <strong>If XR negative + afebrile + pain controlled:</strong><br/>
        Ibuprofen {doses?doses.ibu+" mg":"10 mg/kg"} PO Q6h · PCP follow-up · Return precautions<br/>
        Consider immobilization if fracture suspected despite negative XR
      </Alert>)}
      {localizable==="no"&&(<Alert color={C.amberMid} border={C.amberBorder} bg={C.amberBg} icon="🟡" title="Non-Localizable — Systematic Approach">
        {ageGroup==="toddler"&&<span><strong>Start with XR tibia-fibula AP + lateral</strong> (toddler's fracture most common occult fx)<br/>If negative → consider XR femur, foot<br/><strong>If all negative + suspected occult fracture → immobilize + reimage 7–10 days</strong><br/></span>}
        {ageGroup!=="toddler"&&<span><strong>Examine hips carefully</strong> — log roll, internal rotation assessment<br/>XR bilateral pelvis (AP + frog-leg) if any hip concern<br/></span>}
        If child is afebrile, ambulatory, with normal gait and exam → <strong>may not need imaging at initial visit</strong><br/>
        Discharge with close follow-up and strict return precautions
      </Alert>)}
      <TeachBox id="toddlerFx" teaching={teaching}/>
      <TeachBox id="imaging" teaching={teaching}/>
    </Card>)}

    {/* RESET */}
    {obvious!==null&&(<div style={{textAlign:"center",marginTop:8}}><button onClick={reset} style={{padding:"10px 24px",background:C.white,border:"1.5px solid "+C.rule,borderRadius:8,cursor:"pointer",fontSize:13,fontWeight:600,color:C.muted}}>↻ Reset Walk-Through</button></div>)}
    <PathwayFlowchart/>
  </Pad>);
}


