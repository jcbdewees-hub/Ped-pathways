function RefTriage({teaching}){return(<Pad>
<Q text="Triage & Assessment" sub="Systematic evaluation of the limping child"/>
<TeachBox id="overview" teaching={teaching}/>
<Card title="Life-Threatening / Emergency Conditions" color={C.red}><div style={{marginTop:8}}>
<div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6}}>
{["Septic arthritis (especially hip)","Osteomyelitis","Slipped capital femoral epiphysis","Compartment syndrome","Malignancy (leukemia, bone tumors)","Occult fracture (NAT)","Spinal epidural abscess","Pyomyositis","Testicular torsion","Spontaneous hemarthrosis (hemophilia)"].map(function(item){return <div key={item} style={{background:C.redBg,border:"1px solid "+C.redBorder,borderRadius:6,padding:"6px 8px",fontSize:11,fontWeight:500}}>{item}</div>})}
</div>
</div></Card>
<Card title="Causes by Age" color={C.primary}><div style={{marginTop:8,fontSize:12,lineHeight:1.6}}>
<div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8}}>
<div style={{background:C.redBg,border:"1.5px solid "+C.redBorder,borderRadius:8,padding:"8px"}}><div style={{fontSize:11,fontWeight:700,color:C.red,marginBottom:4}}>Toddler (1–5 yr)</div><div style={{fontSize:10,lineHeight:1.5}}>Toddler's fracture<br/>Transient synovitis<br/>Septic hip<br/>Discitis<br/>DDH<br/>NAT<br/>Leukemia<br/>Hand-foot-mouth</div></div>
<div style={{background:C.amberBg,border:"1.5px solid "+C.amberBorder,borderRadius:8,padding:"8px"}}><div style={{fontSize:11,fontWeight:700,color:C.amberMid,marginBottom:4}}>School Age (5–12)</div><div style={{fontSize:10,lineHeight:1.5}}>Transient synovitis<br/>Legg-Calvé-Perthes<br/>Osteomyelitis<br/>JIA<br/>Sever disease<br/>Osteochondritis dissecans<br/>Growing pains<br/>Tarsal coalition</div></div>
<div style={{background:C.blueBg,border:"1.5px solid "+C.blueBorder,borderRadius:8,padding:"8px"}}><div style={{fontSize:11,fontWeight:700,color:C.blue,marginBottom:4}}>Adolescent (13–19)</div><div style={{fontSize:10,lineHeight:1.5}}>SCFE<br/>Osgood-Schlatter<br/>Stress fracture<br/>Ligament injury<br/>Spondylolysis/listhesis<br/>Osteosarcoma/Ewing<br/>Gonococcal arthritis<br/>Complex regional pain syn</div></div>
</div>
</div></Card>
<Card title="Gait Types" color={C.blue} defaultOpen={false}><div style={{marginTop:8,fontSize:12,lineHeight:1.6}}>
{[["Antalgic","Short stance phase on affected side; pain with weight-bearing","Fracture, infection, inflammation, tumor"],["Trendelenburg","Pelvic tilt toward unaffected side","SCFE, Perthes, DDH, JDM"],["Toe-walking","Child walks on toes","Sever disease, cerebral palsy, tethered cord, myositis"],["Stooping","Hip flexed throughout gait cycle","Appendicitis, psoas abscess, PID, torsion"],["Steppage","Exaggerated hip/knee flexion (foot drop)","Peroneal nerve injury, Charcot-Marie-Tooth"],["Vaulting","Hyperextended knee, vaults over leg","Limb length discrepancy, JIA"]].map(function(r){return <div key={r[0]} style={{marginBottom:8,padding:"6px 8px",background:"#f9fafb",borderRadius:6,border:"1px solid "+C.rule}}><div style={{fontWeight:700,fontSize:12,color:C.primary}}>{r[0]}</div><div style={{fontSize:11,color:C.muted}}>{r[1]}</div><div style={{fontSize:11,marginTop:2}}>{r[2]}</div></div>})}
</div><TeachBox id="gaitTypes" teaching={teaching}/></Card>
<Card title="Key Exam Maneuvers" color={C.primary} defaultOpen={false}><div style={{marginTop:8,fontSize:12,lineHeight:1.6}}>
<strong>Log roll test:</strong> Roll thigh with child supine — pain suggests hip inflammation, infection, or trauma<br/><br/>
<strong>Internal rotation (prone):</strong> Decreased internal rotation → SCFE, Perthes, or septic hip. The pelvis must be flat on the table.<br/><br/>
<strong>Galeazzi test:</strong> Flex hips and knees, feet on table — unequal knee heights suggests DDH or leg length discrepancy<br/><br/>
<strong>Trendelenburg test:</strong> Stand on affected leg — pelvic tilt toward unaffected side = positive (SCFE, Perthes, DDH)<br/><br/>
<strong>FABERE test (figure of 4):</strong> Flexion, abduction, external rotation at hip — pain suggests sacroiliac joint pathology<br/><br/>
<strong>Also examine:</strong> Abdomen (appendicitis, psoas abscess), genitalia (testicular torsion), spine (discitis, epidural abscess), feet (foreign body, warts, blisters)
</div></Card>
</Pad>)}

function RefDecisions({teaching}){return(<Pad>
<Q text="Decision Pathways" sub="Organized by acuity, fever, localizability, and age"/>
<Card title="Febrile + Joint Concern → Septic vs Synovitis" color={C.red}><div style={{fontSize:13,lineHeight:1.6,marginTop:8}}>
<div style={{background:C.redBg,border:"1.5px solid "+C.redBorder,borderRadius:8,padding:"10px 12px",marginBottom:8}}><div style={{fontSize:13,fontWeight:700,color:C.red}}>Septic Arthritis (≥2 Kocher criteria)</div><div style={{fontSize:12,marginTop:2}}>Emergency US → Aspiration → OR for drainage · IV antibiotics after culture · Admit</div></div>
<div style={{background:C.greenBg,border:"1.5px solid "+C.greenBorder,borderRadius:8,padding:"10px 12px"}}><div style={{fontSize:13,fontWeight:700,color:C.greenMid}}>Transient Synovitis (0–1 Kocher criteria)</div><div style={{fontSize:12,marginTop:2}}>NSAIDs · Rest · Discharge with mandatory 24–48h follow-up · Return precautions</div></div>
</div><TeachBox id="septicHip" teaching={teaching}/></Card>
<Card title="Afebrile — Localized Findings" color={C.blue}><div style={{fontSize:13,lineHeight:1.6,marginTop:8}}>
XR AP + lateral of the painful site<br/>
Hip or knee pain → AP + frog-leg of <strong>bilateral pelvis</strong><br/>
Point tenderness at apophysis → clinical diagnosis may suffice (Osgood-Schlatter, Sever)<br/>
Normal XR + afebrile + pain controlled → ibuprofen + PCP follow-up + return precautions
</div><TeachBox id="imaging" teaching={teaching}/></Card>
<Card title="Afebrile — Non-Localizable (Toddler)" color={C.amberMid}><div style={{fontSize:13,lineHeight:1.6,marginTop:8}}>
XR tibia-fibula AP + lateral first (toddler's fracture most common)<br/>
If negative → consider XR femur, foot<br/>
<strong>If suspected occult fracture:</strong> immobilize (splint/CAM boot) + reimage 7–10 days + ortho follow-up<br/>
If asymptomatic out of immobilization → discontinue without further imaging<br/>
<strong>Always consider NAT</strong> if mechanism inconsistent with developmental stage
</div><TeachBox id="toddlerFx" teaching={teaching}/></Card>
<Card title="SCFE — Immediate Actions" color={C.red}><div style={{fontSize:13,lineHeight:1.6,marginTop:8}}>
<div style={{fontFamily:"'IBM Plex Mono',monospace",fontSize:12,color:C.red,fontWeight:600,marginBottom:6}}>Obese adolescent + hip/knee pain + decreased internal rotation = SCFE until proven otherwise</div>
<strong>1. Immediate NON-WEIGHT-BEARING</strong> (crutches or wheelchair)<br/>
<strong>2. XR bilateral pelvis</strong> (AP + frog-leg lateral) — do NOT order unilateral hip series<br/>
<strong>3. Urgent orthopedic consultation</strong> for operative fixation<br/>
Do not force internal rotation on exam — this can worsen the slip<br/>
Bilateral SCFE in 20–40% of cases
</div><TeachBox id="scfe" teaching={teaching}/></Card>
<PathwayFlowchart/>
</Pad>)}

function RefMeds({teaching,doses}){return(<Pad>
<Q text="Medications" sub={doses?"Calculated for "+doses.w+" kg":"Enter weight for calculations"}/>
{!doses&&(<Alert color={C.amberMid} border={C.amberBorder} bg={C.amberBg} icon="⚖️" title="Weight Required">Enter weight in the bar above.</Alert>)}
<Card title="Analgesics" color={C.blue}><div style={{marginTop:8}}>
<DoseRow label="Ibuprofen (10 mg/kg) PO Q6h" value={doses?doses.ibu:"—"} unit={doses?"mg":""}/>
<DoseRow label="Acetaminophen (15 mg/kg) PO Q4h" value={doses?doses.apap:"—"} unit={doses?"mg":""}/>
<DoseRow label="Ketorolac (0.5 mg/kg) IV Q6h (max 30 mg)" value={doses?doses.ketoMax:"—"} unit={doses?"mg":""}/>
</div></Card>
<Card title="Antibiotics — Septic Arthritis / Osteomyelitis" color={C.red}><div style={{marginTop:8}}>
<DoseRow label="Cefazolin (25 mg/kg) IV Q8h" value={doses?doses.cefazolinMax:"—"} unit={doses?"mg":""}/>
<DoseRow label="Clindamycin (10 mg/kg) IV Q8h — MRSA cover" value={doses?doses.clindaMax:"—"} unit={doses?"mg":""}/>
<DoseRow label="Vancomycin (15 mg/kg) IV Q6–8h — severe MRSA" value={doses?doses.vanc:"—"} unit={doses?"mg":""}/>
<DoseRow label="Nafcillin (50 mg/kg) IV Q6h — MSSA" value={doses?doses.nafcillin:"—"} unit={doses?"mg":""}/>
<div style={{fontSize:12,color:C.muted,marginTop:6}}>Antibiotic choice depends on local resistance patterns. Obtain blood cultures and joint aspirate cultures before starting antibiotics. In children &lt;5 years, also cover Kingella kingae (cefazolin covers this).</div>
</div></Card>
<Card title="IV Fluids" color={C.primary}><div style={{marginTop:8}}>
<DoseRow label="NS bolus (20 mL/kg) — if sepsis concern" value={doses?doses.bolus:"—"} unit={doses?"mL":""}/>
</div></Card>
</Pad>)}

function RefDispo({teaching}){return(<Pad>
<Q text="Disposition & References"/>
<Card title="Disposition Summary" color={C.primary}><div style={{marginTop:8}}>
<div style={{background:C.redBg,border:"1.5px solid "+C.redBorder,borderRadius:8,padding:"10px 12px",marginBottom:6}}><div style={{fontSize:13,fontWeight:700,color:C.red}}>EMERGENT CONSULT / ADMIT</div><div style={{fontSize:12,marginTop:2}}>Septic arthritis → OR drainage · SCFE → non-WB + urgent ortho fixation · Osteomyelitis → IV antibiotics · Compartment syndrome → fasciotomy · Malignancy → staging + oncology · NAT → skeletal survey, social work, CPS · Spinal epidural abscess → MRI + neurosurgery</div></div>
<div style={{background:C.amberBg,border:"1.5px solid "+C.amberBorder,borderRadius:8,padding:"10px 12px",marginBottom:6}}><div style={{fontSize:13,fontWeight:700,color:C.amberMid}}>OUTPATIENT SPECIALTY REFERRAL</div><div style={{fontSize:12,marginTop:2}}>Suspected toddler's fracture (neg XR) → immobilize + reimage 7–10 days · Legg-Calvé-Perthes → orthopedics · JIA suspected → rheumatology · Provisional diagnosis apparent → appropriate specialist</div></div>
<div style={{background:C.greenBg,border:"1.5px solid "+C.greenBorder,borderRadius:8,padding:"10px 12px"}}><div style={{fontSize:13,fontWeight:700,color:C.greenMid}}>DISCHARGE WITH PRECAUTIONS</div><div style={{fontSize:12,marginTop:2}}>Afebrile + normal XR + pain controlled with ibuprofen → PCP follow-up · Transient synovitis (low Kocher) → NSAIDs + f/u 24–48h</div></div>
</div><TeachBox id="disposition" teaching={teaching}/></Card>
<Card title="Return Precautions" color={C.amberMid}><div style={{fontSize:13,lineHeight:1.7,marginTop:8}}>
<strong>Return immediately for:</strong><br/>
— Fever develops<br/>
— Worsening pain or inability to bear weight<br/>
— Night pain or pain that wakes child from sleep<br/>
— Swelling, redness, or warmth of a joint<br/>
— Limp not improving within 7–10 days<br/>
— Any new neurologic symptoms (weakness, numbness, bowel/bladder changes)
</div></Card>
<Card title="Differential Reminder — Don't Forget to Examine" color={C.blue} defaultOpen={false}><div style={{fontSize:13,lineHeight:1.7,marginTop:8}}>
<strong>Hip pathology causes knee pain</strong> — always examine both<br/>
<strong>Abdominal pathology causes hip/thigh pain</strong> — appendicitis, psoas abscess, PID<br/>
<strong>Back pathology causes leg pain</strong> — discitis, epidural abscess, disc herniation<br/>
<strong>GU pathology:</strong> testicular torsion presents with wide-based gait<br/>
<strong>Feet:</strong> always check soles for foreign bodies, warts, blisters<br/>
<strong>Skin:</strong> check for rashes (IgA vasculitis, Lyme, serum sickness, rheumatic fever)
</div></Card>
<Card title="References" color={C.muted} defaultOpen={false}><div style={{fontSize:11,lineHeight:1.7,marginTop:8,color:C.muted}}>1. Clark MC, Thompson A. Evaluation of limp in children. <em>UpToDate</em> 2025.<br/>2. Fischer SU, Beattie TF. The limping child: epidemiology, assessment and outcome. <em>J Bone Joint Surg Br</em> 1999; 81:1029.<br/>3. Perry DC, Bruce C. Evaluating the child who presents with an acute limp. <em>BMJ</em> 2010; 341:c4250.<br/>4. Kocher MS et al. Differentiating between septic arthritis and transient synovitis of the hip. <em>J Bone Joint Surg Am</em> 1999; 81:1662.<br/>5. Caird MS et al. Validation of a clinical prediction algorithm for the differentiation of septic arthritis. <em>J Bone Joint Surg Am</em> 2006; 88:1251.<br/>6. ACR Appropriateness Criteria: Acutely Limping Child Up to Age 5. Revised 2018.<br/>7. Morancie NA, Helton MR. Evaluating the Child With a Limp. <em>Am Fam Physician</em> 2023; 107:474.</div></Card>
</Pad>)}


