          <g transform="translate(80,228)"><polygon points="0,-14 50,0 0,14 -50,0" fill="#f8fafc" stroke="#94a3b8" strokeWidth={1.2}/><T x={0} y={-2} size={6} weight={700}>Septic</T><T x={0} y={7} size={6} weight={700}>joint?</T></g>
