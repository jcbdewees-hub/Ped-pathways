          <Arrow x1={305} y1={116} x2={400} y2={146}/>
          <T x={360} y={130} size={6} color={gC} weight={600}>No</T>
          {/* Febrile branch */}
          <Box x={10} y={146} w={140} h={50} fill={rBg} stroke={rBd} sw={1.5}><T x={80} y={158} size={7} weight={700} color={rC}>INFECTION WORKUP</T><T x={80} y={168} size={6}>Joint pain → US hip · Labs</T><T x={80} y={178} size={6}>CBC, ESR/CRP, blood cx</T><T x={80} y={188} size={6} color={rC}>Kocher criteria → Aspiration?</T></Box>
