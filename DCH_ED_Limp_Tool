          <line x1={305} y1={66} x2={420} y2={66} stroke="#94a3b8" strokeWidth={1}/><Arrow x1={420} y1={66} x2={420} y2={82} color={gC}/>
          <T x={370} y={62} size={6} color={gC} weight={600}>Yes</T>
          <Box x={380} y={82} w={80} h={24} fill={gBg} stroke={gBd}><T x={420} y={92} size={6} weight={700} color={gC}>TREAT CAUSE</T><T x={420} y={102} size={5.5}>Wound care / splint</T></Box>
          <Arrow x1={240} y1={82} x2={240} y2={100}/>
