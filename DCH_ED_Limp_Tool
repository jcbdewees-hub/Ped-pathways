          <g transform="translate(240,116)"><polygon points="0,-16 65,0 0,16 -65,0" fill="#f8fafc" stroke="#94a3b8" strokeWidth={1.2}/><T x={0} y={-3} size={7} weight={700}>Febrile or signs</T><T x={0} y={7} size={7} weight={700}>of infection?</T></g>
          <Arrow x1={175} y1={116} x2={80} y2={146} color={rC}/>
